{
  "entities": {
    "Bottle": {
      "title": "Bottle",
      "description": "A bottle of alcohol purchased and tracked by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the bottle" },
        "name": { "type": "string", "description": "Name of the bottle" },
        "type": { "type": "string", "description": "Type of alcohol (e.g., Beer, Wine)" },
        "purchaseDate": { "type": "string", "format": "date-time", "description": "Date of purchase" },
        "price": { "type": "number", "description": "Price paid for the bottle" },
        "volume": { "type": "number", "description": "Volume in ml" },
        "status": { "type": "string", "enum": ["unopened", "opened", "finished"], "description": "Current status of the bottle" },
        "openedAt": { "type": "string", "format": "date-time", "description": "Date when the bottle was opened" },
        "finishedAt": { "type": "string", "format": "date-time", "description": "Date when the bottle was finished" },
        "uid": { "type": "string", "description": "UID of the owner" }
      },
      "required": ["id", "name", "type", "purchaseDate", "price", "volume", "status", "uid"]
    },
    "Mood": {
      "title": "Mood",
      "description": "A user's mood entry for a specific date.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the mood entry" },
        "date": { "type": "string", "format": "date", "description": "Date of the mood entry" },
        "rating": { "type": "integer", "description": "Mood rating from 1 (bad) to 5 (good)" },
        "note": { "type": "string", "description": "Optional note about the mood" },
        "uid": { "type": "string", "description": "UID of the owner" }
      },
      "required": ["id", "date", "rating", "uid"]
    }
  },
  "firestore": {
    "/bottles/{bottleId}": {
      "schema": "Bottle",
      "description": "Collection of alcohol bottles tracked by users."
    },
    "/moods/{moodId}": {
      "schema": "Mood",
      "description": "Collection of user mood entries."
    }
  }
}
